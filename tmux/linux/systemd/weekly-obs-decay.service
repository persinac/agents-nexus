[Unit]
Description=Weekly Obsidian note decay and archival

[Service]
Type=oneshot
WorkingDirectory=__AGENTS_NEXUS_DIR__
ExecStart=/bin/bash -c 'source __HOME__/.tmux/env.sh 2>/dev/null; uv run scripts/obs-decay-monitor.py'
Environment=HOME=__HOME__
Environment=VAULT_DIR=__HOME__/vault
StandardOutput=journal
StandardError=journal
