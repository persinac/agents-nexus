{
  "env": {
    "ENABLE_TOOL_SEARCH": "true"
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.tmux/hook-stop.sh; true"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/auto-checkpoint.sh",
            "async": true,
            "timeout": 120
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.tmux/hook-pretooluse.sh; true"
          }
        ]
      },
      {
        "matcher": "SendMessage",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.tmux/hook-sendmessage-bus.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.tmux/hook-notification.sh; true"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.tmux/hook-sessionstart.sh; true"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(glab mr *)",
      "Bash(glab pipeline *)",
      "Bash(glab ci *)",
      "Bash(glab api *)",
      "Bash(git branch *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git status*)",
      "Bash(git fetch *)",
      "Bash(git pull *)",
      "Bash(git rebase *)",
      "Bash(git push *)",
      "Bash(git remote *)",
      "Bash(git rev-parse *)",
      "Bash(python3 -c *)",
      "Bash(python3 -m *)",
      "Bash(echo *)",
      "Bash(env)",
      "Bash(grep *)",
      "Bash(uv run *)",
      "Bash($HOME/.tmux/agent-send.sh *)",
      "Bash($HOME/.tmux/agent-registry.sh *)",
      "mcp__agent-memory__*"
    ]
  }
}
