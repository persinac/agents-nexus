<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.garner.devn-relay</string>
    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/socat</string>
        <string>-d</string>
        <string>TCP-LISTEN:54777,bind=0.0.0.0,reuseaddr,fork,range=127.0.0.0/8</string>
        <string>TCP:127.0.0.1:54776</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/tmp/devn-relay/socat.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/devn-relay/socat.log</string>
    <key>ProcessType</key>
    <string>Background</string>
</dict>
</plist>
