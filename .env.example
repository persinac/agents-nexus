# agents-nexus — Docker Compose environment
# Copy to .env and fill in secrets before running `docker compose up -d`

# ── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_DB=agents
POSTGRES_USER=agents
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# DATABASE_URL for native tools (mnemon MCP server, memory scripts).
# Points to the Docker-managed Postgres on localhost.
DATABASE_URL=postgresql://agents:changeme@localhost:5432/agents?sslmode=disable

# ── Ollama ───────────────────────────────────────────────────────────────────
OLLAMA_PORT=11434
# For native mnemon / spark (outside Docker):
OLLAMA_BASE_URL=http://localhost:11434

# ── Spark (semantic repo search) ─────────────────────────────────────────────
# Absolute path to the repos directory spark will index
REPOS_PATH=~/repos
SPARK_PORT=8343

# GitLab credentials (optional — enables repo metadata + webhook re-indexing)
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=
SPARK_WEBHOOK_SECRET=

# Cloudflare tunnel (optional — exposes spark to GitLab for webhooks)
CLOUDFLARE_TUNNEL_TOKEN=

# ── mnemon flush daemon ───────────────────────────────────────────────────────
# Directory where tmux hook scripts write memory-events.jsonl on the host
HOST_TMUX_DIR=~/.tmux

# ── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_PORT=8421
